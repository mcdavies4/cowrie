# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only, never expose to browser

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000          # set to your Vercel URL in prod
PLATFORM_FEE_PERCENT=0                              # default fee % you keep (per-deal field can override)

# ---- Stripe (GBP/USD/EUR rail) ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx                    # from `stripe listen` or dashboard endpoint

# ---- Flutterwave (NGN/African rail) ----
FLW_SECRET_KEY=FLWSECK_TEST-xxx
FLW_SECRET_HASH=your-webhook-secret-hash           # set this same value in FLW dashboard > Webhooks

# ---- Resend (optional: payout + accept emails). If unset, links are logged to console. ----
RESEND_API_KEY=
EMAIL_FROM=Cowrie <noreply@yourdomain>
